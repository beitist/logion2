# ============================================================
# Logion 2 — .gitignore (Public Repository)
# ============================================================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
*.db

# --- Node.js ---
node_modules/
dist/
dist-ssr/
*.local

# --- Runtime Data ---
backend/projectdata/
backend/uploads/
uploads/
backups/
app.log
app.log.*
app.json
app.json.*

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors & IDEs ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Debug & Dev Artifacts ---
*.txt
!requirements.txt
!README.md

# --- Test Data & Old Files ---
resource/
documentation/
briefings/
scripts/
old/
test/
tests/
backend/old/
backend/old_tests/
backend/tests/
backend/migrations/

# -- FOLDERS -- 
documentation
old

# --- One-off scripts (root & backend root) ---
/repro_*.py
/backend/debug_*.py
/backend/analyze_*.py
/backend/check_*.py
/backend/verify_*.py
/backend/migrate_*.py
/backend/repro_*.py
/backend/create_*.py
/backend/add_*.py


# --- Misc ---
*.docx
*.png
*.graffle
.claude/
.pytest_cache/
